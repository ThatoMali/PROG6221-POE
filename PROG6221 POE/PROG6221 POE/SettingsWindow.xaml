<Window x:Class="PROG6221_POE.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings - SecureCore" Height="450" Width="550"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E2E">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#2D2D3D" Padding="15" CornerRadius="10" Margin="0,0,0,15">
            <StackPanel>
                <TextBlock Text="Settings" FontSize="24" FontWeight="Bold" 
                           Foreground="#00CED1" HorizontalAlignment="Center"/>
                <TextBlock Text="Configure your SecureCore preferences" FontSize="14" 
                           Foreground="#AAA" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Settings Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0,0,0,10">

                <!-- Voice Settings -->
                <Border Background="#2D2D3D" Padding="15" CornerRadius="8" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="Voice Settings" Foreground="#00CED1" 
                                   FontWeight="Bold" FontSize="16" Margin="0,0,0,10"/>
                        <CheckBox x:Name="chkEnableVoice" Content="Enable Voice Responses" 
                                  Foreground="White" FontSize="14" Margin="5,0,0,10" IsChecked="True"/>
                        <CheckBox x:Name="chkAutoGreeting" Content="Play Greeting on Startup" 
                                  Foreground="White" FontSize="14" Margin="5,0,0,0" IsChecked="True"/>
                    </StackPanel>
                </Border>

                <!-- Sentiment Settings -->
                <Border Background="#2D2D3D" Padding="15" CornerRadius="8" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="Sentiment Analysis" Foreground="#00CED1" 
                                   FontWeight="Bold" FontSize="16" Margin="0,0,0,10"/>
                        <CheckBox x:Name="chkEnableSentiment" Content="Enable Sentiment Detection" 
                                  Foreground="White" FontSize="14" Margin="5,0,0,10" IsChecked="True"/>
                        <CheckBox x:Name="chkShowEmoji" Content="Show Emoji Indicators" 
                                  Foreground="White" FontSize="14" Margin="5,0,0,0" IsChecked="True"/>
                    </StackPanel>
                </Border>

                <!-- Appearance Settings -->
                <Border Background="#2D2D3D" Padding="15" CornerRadius="8" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="Appearance" Foreground="#00CED1" 
                                   FontWeight="Bold" FontSize="16" Margin="0,0,0,10"/>

                        <TextBlock Text="Theme:" Foreground="White" FontSize="14" Margin="0,0,0,5"/>
                        <ComboBox x:Name="cboTheme" Background="#4A4A5A" Foreground="White" 
                                  Padding="10" Margin="0,0,0,10" Height="35">
                            <ComboBoxItem Content="Dark" IsSelected="True"/>
                            <ComboBoxItem Content="Light"/>
                            <ComboBoxItem Content="Blue"/>
                            <ComboBoxItem Content="Green"/>
                        </ComboBox>

                        <TextBlock Text="Font Size:" Foreground="White" FontSize="14" Margin="0,0,0,5"/>
                        <Slider x:Name="sliderFontSize" Minimum="10" Maximum="20" Value="13" 
                                Foreground="#00CED1" Margin="0,0,0,10"/>
                        <TextBlock Text="{Binding ElementName=sliderFontSize, Path=Value, StringFormat='Current Size: {0:F0}px'}" 
                                   Foreground="#AAA" FontSize="12" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Database Settings -->
                <Border Background="#2D2D3D" Padding="15" CornerRadius="8" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="Database Settings" Foreground="#00CED1" 
                                   FontWeight="Bold" FontSize="16" Margin="0,0,0,10"/>

                        <TextBlock Text="Connection String:" Foreground="White" FontSize="14" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtConnectionString" Background="#4A4A5A" Foreground="White"
                                 BorderThickness="0" Padding="10" FontSize="12" Height="35"
                                 Text="Server=localhost;Database=PROG6221POEDB;Trusted_Connection=True;"/>

                        <Button Content="Test Connection" Background="#4A4A5A" 
                                Foreground="White" Padding="15,8" Margin="0,10,0,0"
                                BorderThickness="0" Cursor="Hand" Click="BtnTestConnection_Click"/>
                    </StackPanel>
                </Border>

                <!-- About -->
                <Border Background="#2D2D3D" Padding="15" CornerRadius="8">
                    <StackPanel>
                        <TextBlock Text="About" Foreground="#00CED1" 
                                   FontWeight="Bold" FontSize="16" Margin="0,0,0,10"/>
                        <TextBlock Text="SecureCore - Cybersecurity Awareness Chatbot" 
                                   Foreground="White" FontSize="14"/>
                        <TextBlock Text="Version 3.0" Foreground="#AAA" FontSize="12" Margin="0,5,0,0"/>
                        <TextBlock Text="Built with WPF and C#" Foreground="#AAA" FontSize="12"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Bottom Buttons -->
        <Border Grid.Row="2" Background="#2D2D3D" Padding="15" CornerRadius="10" Margin="0,15,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" x:Name="txtStatus" Text="Ready" 
                           Foreground="#4CAF50" FontSize="12" VerticalAlignment="Center"/>

                <Button Grid.Column="1" Content="Save Settings" Background="#00CED1" 
                        Foreground="#1A1A2E" FontWeight="Bold" Padding="20,10" Margin="0,0,10,0"
                        BorderThickness="0" Cursor="Hand" Click="BtnSave_Click"/>

                <Button Grid.Column="2" Content="Close" Background="#FF6B6B" 
                        Foreground="White" FontWeight="Bold" Padding="20,10"
                        BorderThickness="0" Cursor="Hand" Click="BtnClose_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>