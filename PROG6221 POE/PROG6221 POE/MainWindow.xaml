<Window x:Class="PROG6221_POE.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SecureCore - Cybersecurity Chatbot" 
        Height="750" Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E2E">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ASCII Art Header -->
        <Border Grid.Row="0" Background="#1A1A2E" Padding="15">
            <StackPanel>
                <TextBlock FontFamily="Consolas" FontSize="10" Foreground="#00CED1" FontWeight="Bold"
                           TextAlignment="Center"
                           Text="╔═══════════════════════════════════════════════════════════════════╗&#xD;&#xA;║                                                               ║&#xD;&#xA;║    _____                            _____                 ║&#xD;&#xA;║   / ____|                          / ____|                ║&#xD;&#xA;║  | (___   ___  ___ _   _ _ __ ___ | |     ___  _ __ ___   ║&#xD;&#xA;║   \___ \ / _ \/ __| | | | '__/ _ \| |    / _ \| '__/ _ \  ║&#xD;&#xA;║   ____) |  __/ (__| |_| | | |  __/| |___| (_) | | |  __/  ║&#xD;&#xA;║  |_____/ \___|\___|\__,_|_|  \___| \_____\___/|_|  \___|  ║&#xD;&#xA;║                                                               ║&#xD;&#xA;║                    S E C U R E  C O R E                       ║&#xD;&#xA;╚═══════════════════════════════════════════════════════════════════╝"/>
                <TextBlock Text="Cybersecurity Awareness Chatbot" FontSize="18" FontWeight="Bold" 
                           Foreground="#00CED1" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                <TextBlock Text="Your 24/7 Security Assistant" FontSize="12" Foreground="#AAA" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Navigation Toolbar -->
        <Border Grid.Row="1" Background="#2D2D3D" Padding="10" Margin="10,10,10,5" CornerRadius="10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="Manage Tasks" Background="#00CED1" 
                        Foreground="#1A1A2E" FontWeight="Bold" Padding="15,8" Margin="5"
                        BorderThickness="0" Cursor="Hand" Click="BtnOpenTasks_Click"/>

                <Button Content="Start Quiz" Background="#FFA500" 
                        Foreground="#1A1A2E" FontWeight="Bold" Padding="15,8" Margin="5"
                        BorderThickness="0" Cursor="Hand" Click="BtnOpenQuiz_Click"/>

                <Button Content="View Activity Log" Background="#4A4A5A" 
                        Foreground="White" FontWeight="Bold" Padding="15,8" Margin="5"
                        BorderThickness="0" Cursor="Hand" Click="BtnOpenLog_Click"/>

                <Button Content="Settings" Background="#6C5CE7" 
                        Foreground="White" FontWeight="Bold" Padding="15,8" Margin="5"
                        BorderThickness="0" Cursor="Hand" Click="BtnOpenSettings_Click"/>
            </StackPanel>
        </Border>

        <!-- Name Input -->
        <Border Grid.Row="2" Background="#2D2D3D" Padding="15" Margin="10,5,10,5" CornerRadius="10">
            <StackPanel>
                <TextBlock Text="Enter your name:" Foreground="White" FontSize="14"/>
                <Grid Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="txtUserName" Grid.Column="0" Background="#4A4A5A" Foreground="White"
                             BorderThickness="0" Padding="10" FontSize="14"/>
                    <Button x:Name="btnStartChat" Grid.Column="1" Content="Start Chat" Background="#00CED1"
                            Foreground="#1A1A2E" FontWeight="Bold" Padding="20,10" Margin="10,0,0,0"
                            BorderThickness="0" Cursor="Hand" Click="BtnStartChat_Click"/>
                    <Button x:Name="btnClearChat" Grid.Column="2" Content="Clear Chat" Background="#FF6B6B"
                            Foreground="White" FontWeight="Bold" Padding="20,10" Margin="10,0,0,0"
                            BorderThickness="0" Cursor="Hand" IsEnabled="False" Click="BtnClearChat_Click"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Chat Display -->
        <ListBox x:Name="lstChatDisplay" Grid.Row="3" Background="#252535" BorderThickness="0"
                 Margin="10,5,10,5" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border CornerRadius="10" Padding="12,8" Margin="5,3"
                            HorizontalAlignment="{Binding Alignment}" MaxWidth="450"
                            Background="{Binding BackgroundColor}">
                        <StackPanel>
                            <TextBlock Text="{Binding Sender}" Foreground="{Binding SenderColor}" 
                                       FontSize="10" FontWeight="Bold"/>
                            <TextBlock Text="{Binding Text}" Foreground="White" FontSize="13" TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding Time}" Foreground="#888" FontSize="9" HorizontalAlignment="Right"/>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Status Bar -->
        <Border Grid.Row="4" Background="#2D2D3D" Padding="10" Margin="10,5,10,5" CornerRadius="8" Height="40">
            <WrapPanel>
                <TextBlock x:Name="txtSentiment" Text="😊 Sentiment: Neutral" Foreground="#AAA" FontSize="11" VerticalAlignment="Center"/>
                <TextBlock x:Name="txtUserInfo" Text="" Foreground="#00CED1" FontSize="11" Margin="20,0,0,0" VerticalAlignment="Center"/>
                <TextBlock x:Name="txtMessageCount" Text="" Foreground="#888" FontSize="11" Margin="20,0,0,0" VerticalAlignment="Center"/>
            </WrapPanel>
        </Border>

        <!-- Message Input -->
        <Border Grid.Row="5" Background="#2D2D3D" Padding="15" Margin="10,5,10,10" CornerRadius="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="txtMessageInput" Grid.Column="0" Background="#4A4A5A" Foreground="White"
                         BorderThickness="0" Padding="10" FontSize="14" IsEnabled="False"
                         KeyDown="TxtMessageInput_KeyDown"/>
                <Button x:Name="btnSend" Grid.Column="1" Content="Send" Background="#00CED1"
                        Foreground="#1A1A2E" FontWeight="Bold" Padding="20,10" Margin="10,0,5,0"
                        BorderThickness="0" IsEnabled="False" Cursor="Hand" Click="BtnSend_Click"/>
                <Button x:Name="btnVoice" Grid.Column="2" Content="🔊 Voice" Background="#FF6B6B"
                        Foreground="White" FontWeight="Bold" Padding="20,10" Margin="5,0,0,0"
                        BorderThickness="0" IsEnabled="False" Cursor="Hand" Click="BtnVoice_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>