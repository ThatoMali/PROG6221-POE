<Window x:Class="PROG6221_POE.TaskManagementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Task Management" Height="500" Width="700"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E2E">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#2D2D3D" Padding="15" CornerRadius="10" Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Text="Task Management" FontSize="24" FontWeight="Bold" 
                           Foreground="#00CED1" HorizontalAlignment="Center"/>
                <TextBlock Text="Manage your cybersecurity tasks" FontSize="14" 
                           Foreground="#AAA" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Task List -->
        <ListBox x:Name="lstTasks" Grid.Row="1" Background="#252535" 
                 BorderThickness="0" Margin="0,0,0,10"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border CornerRadius="8" Padding="12,8" Margin="5,3"
                            Background="#3D3D4D">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="{Binding Status}" 
                                       FontSize="16" Margin="0,0,10,0"/>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="{Binding Title}" Foreground="White" 
                                           FontWeight="Bold" FontSize="14"/>
                                <TextBlock Text="{Binding Description}" Foreground="#AAA" 
                                           FontSize="12" TextWrapping="Wrap"/>
                                <TextBlock Text="{Binding Reminder}" Foreground="#888" 
                                           FontSize="11"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="10,0,0,0">
                                <Button Content="Complete" Background="#4CAF50" 
                                        Foreground="White" Padding="10,5" Margin="0,0,5,0"
                                        BorderThickness="0" Cursor="Hand"
                                        Click="BtnComplete_Click" Tag="{Binding Id}"/>
                                <Button Content="Delete" Background="#FF6B6B" 
                                        Foreground="White" Padding="10,5"
                                        BorderThickness="0" Cursor="Hand"
                                        Click="BtnDelete_Click" Tag="{Binding Id}"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Add Task Section -->
        <Border Grid.Row="2" Background="#2D2D3D" Padding="15" CornerRadius="10" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="Add New Task" 
                           Foreground="#00CED1" FontWeight="Bold" Margin="0,0,0,5"/>

                <TextBox x:Name="txtTaskTitle" Grid.Row="1" Grid.Column="0" 
                         Background="#4A4A5A" Foreground="White" Padding="10"
                         BorderThickness="0" Text="Enter task title..."/>

                <TextBox x:Name="txtTaskDescription" Grid.Row="2" Grid.Column="0" 
                         Background="#4A4A5A" Foreground="White" Padding="10" Margin="0,5,0,0"
                         BorderThickness="0" Text="Enter description..."/>

                <StackPanel Grid.Row="1" Grid.Column="1" Grid.RowSpan="2" 
                            Orientation="Vertical" Margin="10,0,0,0">
                    <Button Content="Add Task" Background="#00CED1" 
                            Foreground="#1A1A2E" FontWeight="Bold" 
                            Padding="20,15" Margin="0,0,0,5"
                            BorderThickness="0" Cursor="Hand"
                            Click="BtnAddTask_Click"/>
                    <Button Content="Refresh" Background="#4A4A5A" 
                            Foreground="White" Padding="20,10"
                            BorderThickness="0" Cursor="Hand"
                            Click="BtnRefresh_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Close Button -->
        <Button Grid.Row="3" Content="Close" Background="#FF6B6B" 
                Foreground="White" FontWeight="Bold" Padding="20,10"
                BorderThickness="0" Cursor="Hand" HorizontalAlignment="Right"
                Click="BtnClose_Click"/>
    </Grid>
</Window>