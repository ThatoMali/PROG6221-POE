<Window x:Class="PROG6221_POE.ActivityLogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Activity Log" Height="500" Width="800"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E2E">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#2D2D3D" Padding="15" CornerRadius="10" Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Text="Activity Log" FontSize="24" FontWeight="Bold" 
                           Foreground="#00CED1" HorizontalAlignment="Center"/>
                <TextBlock x:Name="txtTotal" Text="Total Entries: 0" 
                           FontSize="14" Foreground="#AAA" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Log Display -->
        <ListBox x:Name="lstLog" Grid.Row="1" Background="#252535" 
                 BorderThickness="0" Margin="0,0,0,10"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border CornerRadius="8" Padding="12,8" Margin="5,3"
                            Background="#3D3D4D">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding Timestamp, StringFormat='{}{0:yyyy-MM-dd HH:mm:ss}'}" 
                                           Foreground="#888" FontSize="11"/>
                                <TextBlock Grid.Column="1" Text="{Binding Action}" 
                                           Foreground="#00CED1" FontWeight="Bold" 
                                           FontSize="13" Margin="10,0,0,0"/>
                            </Grid>
                            <TextBlock Text="{Binding Details}" Foreground="#AAA" 
                                       FontSize="12" TextWrapping="Wrap" Margin="0,5,0,0"/>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Controls -->
        <Border Grid.Row="2" Background="#2D2D3D" Padding="10" CornerRadius="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Button Content="Refresh" Background="#4A4A5A" 
                            Foreground="White" Padding="15,8" Margin="0,0,5,0"
                            BorderThickness="0" Cursor="Hand"
                            Click="BtnRefresh_Click"/>
                    <Button Content="Clear" Background="#FF6B6B" 
                            Foreground="White" Padding="15,8"
                            BorderThickness="0" Cursor="Hand"
                            Click="BtnClear_Click"/>
                </StackPanel>

                <Button Grid.Column="1" Content="Show All" Background="#00CED1" 
                        Foreground="#1A1A2E" FontWeight="Bold" Padding="15,8" Margin="0,0,5,0"
                        BorderThickness="0" Cursor="Hand"
                        Click="BtnShowAll_Click"/>

                <Button Grid.Column="2" Content="Close" Background="#FF6B6B" 
                        Foreground="White" FontWeight="Bold" Padding="15,8"
                        BorderThickness="0" Cursor="Hand"
                        Click="BtnClose_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>